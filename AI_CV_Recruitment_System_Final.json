    {
      "parameters": {
        "promptType": "define",
        "text": "=Please analyze the following candidate CV and return a complete JSON evaluation.\n\n=== CANDIDATE DETAILS ===\nEmail: {{ $json.candidateEmail }}\nReceived: {{ $json.receivedDate }}\nFile Type: {{ $json.extractMethod }}\n\n=== CV TEXT ===\n{{ $json.cvText }}\n\n=== REQUIRED JSON OUTPUT ===\n{\n  \"candidateName\": \"Full name from CV\",\n  \"email\": \"candidate email\",\n  \"phone\": \"phone or null\",\n  \"score\": 75,\n  \"decision\": \"interview\",\n  \"experienceYears\": 3,\n  \"currentRole\": \"Recent job title\",\n  \"currentCompany\": \"Recent company\",\n  \"education\": \"Degree and university\",\n  \"skills\": [\"Skill 1\", \"Skill 2\", \"Skill 3\"],\n  \"strengths\": [\"Strength 1\", \"Strength 2\"],\n  \"weaknesses\": [\"Weakness 1\"],\n  \"recommendation\": \"Professional summary max 20 words\"\n}\n\nReturn ONLY the JSON. No extra text. No markdown. No backticks.",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "=You are a senior HR analyst and recruitment specialist with 10+ years of experience in talent acquisition and CV evaluation.\n\nYour job is to analyze candidate CVs objectively and return a structured JSON evaluation.\n\nSTRICT RULES:\n1. Return ONLY a valid JSON object\n2. No markdown, no backticks, no explanations\n3. Score must be 0 to 100\n4. Decision must be: \"interview\", \"waitlist\", or \"rejected\"\n5. If phone missing, set null\n\nSCORING GUIDE:\n- 80 to 100 = interview\n- 50 to 79  = waitlist\n- 0 to 49   = rejected\n\nEVALUATION CRITERIA:\n- Relevant work experience (35%)\n- Technical skills match (30%)\n- Education and certifications (20%)\n- CV presentation (15%)"
        }
      },
