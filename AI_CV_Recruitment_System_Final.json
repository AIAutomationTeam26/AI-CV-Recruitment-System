        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"meta-llama/llama-4-scout-17b-16e-instruct\",\n  \"messages\": [{\"role\": \"user\", \"content\": [{\"type\": \"image_url\", \"image_url\": {\"url\": \"={{ 'data:' + $binary.attachment0.mimeType + ';base64,' + $binary.attachment0.data }}\"}}, {\"type\": \"text\", \"text\": \"Extract all text from this scanned PDF CV. Return only raw text.\"}]}],\n  \"max_tokens\": 2000\n}",
        "options": {}
      },
      "id": "a35bdc25-9f60-470e-af4f-503283c546f7",
      "name": "Groq OCR (Scanned PDF)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        0
      ],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 3000,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst binary = item.binary || {};\nconst keys = Object.keys(binary);\nconst attKey = keys.find(k => binary[k]?.mimeType?.startsWith('image/')) || keys.find(k => k.startsWith('attachment')) || keys[0];\nif (!attKey) throw new Error('No attachment found');\nconst mimeType = binary[attKey].mimeType || 'image/png';\nconst data = binary[attKey].data;\nif (!data) throw new Error('Binary data empty!');\nreturn [{\n  json: {\n    imageUrl: 'data:' + mimeType + ';base64,' + data,\n    mimeType: mimeType,\n    fromEmail: item.json?.from?.value?.[0]?.address || '',\n    subject: item.json?.subject || ''\n  },\n  binary: binary\n}];"
      },
      "id": "6ed3fdda-f591-4c01-8df6-eddb6b82e9dc",
      "name": "Prepare Image Data",
