    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.text || $input.item.json.data || '';\nconst text = raw.trim();\nif (text.length > 10) {\n  return [{\n    json: {\n      cvText: text.substring(0, 6000),\n      method: 'pdf_direct',\n      fromEmail: $input.item.json.from || '',\n      subject: $input.item.json.subject || ''\n    },\n    binary: $input.item.binary\n  }];\n} else {\n  return [{\n    json: {\n      cvText: '',\n      method: 'pdf_needs_ocr',\n      fromEmail: $input.item.json.from || '',\n      subject: $input.item.json.subject || ''\n    },\n    binary: $input.item.binary\n  }];\n}"
      },
      "id": "b6d0f2cd-0c63-44f0-a4dd-53978a90b1fb",
      "name": "Check PDF Has Text",
      "type": "n8n-nodes-base.code",
