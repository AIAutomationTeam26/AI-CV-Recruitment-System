      "id": "1e08d0a5-e6c9-4efa-95a5-7c2b4d58f55d",
      "name": "Extract DOCX Text",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        0,
        512
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.item;\nconst json = item.json;\nlet cvText = '';\nlet method = 'unknown';\nif (json.ParsedResults && json.ParsedResults[0]) {\n  cvText = json.ParsedResults[0].ParsedText || '';\n  method = 'ocrspace';\n}\nelse if (json.cvText && json.cvText.length > 10) {\n  cvText = json.cvText;\n  method = json.method || 'pdf_direct';\n}\nelse if (json.text && json.text.length > 10) {\n  cvText = json.text;\n  method = 'pdf_direct';\n}\nelse if (json.choices && json.choices[0]) {\n  cvText = json.choices[0].message?.content || '';\n  method = 'groq_ocr';\n}\nelse if (json.data) {\n  cvText = json.data;\n  method = 'docx_extract';\n}\nelse {\n  cvText = 'OCR_FAILED';\n  method = 'ocr_failed';\n}\nreturn [{\n  json: {\n    cvText: cvText.substring(0, 6000),\n    method: method,\n    fromEmail: json.fromEmail || json.from || '',\n    subject: json.subject || '',\n    ocrFailed: method === 'ocr_failed'\n  }\n}];"
      },
      "id": "ddc0e373-d2e8-491c-b7d5-5c22dbf10387",
      "name": "Normalize Extracted Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        320
      ],
      "onError": "continueErrorOutput"
    },
